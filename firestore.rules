rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isReviewOwner(reviewId) {
      return isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/reviews/$(reviewId)).data.userId;
    }

    function isCommentOwner(reviewId, commentId) {
      return isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/reviews/$(reviewId)/comments/$(commentId)).data.userId;
    }

    // Users collection
    match /users/{userId} {
      // 모든 인증 사용자는 다른 사용자의 프로필 읽기 가능
      allow read: if isAuthenticated();
      // 자신의 프로필만 수정 가능
      allow update: if isOwner(userId) && isValidUserUpdate(request.resource.data);
      // 회원가입 시 생성 (Auth 트리거)
      allow create: if isOwner(userId) && isValidUserCreate(request.resource.data);
      // 자신의 프로필만 삭제 가능
      allow delete: if isOwner(userId);
    }

    // Reviews collection
    match /reviews/{reviewId} {
      // 모든 인증 사용자는 리뷰 읽기 가능
      allow read: if isAuthenticated();
      // 인증 사용자만 리뷰 작성 가능
      allow create: if isAuthenticated() && isValidReviewCreate(request.resource.data, request.auth.uid);
      // 리뷰 작성자만 수정/삭제 가능
      allow update, delete: if isReviewOwner(reviewId);

      // Comments subcollection
      match /comments/{commentId} {
        // 모든 인증 사용자는 댓글 읽기 가능
        allow read: if isAuthenticated();
        // 인증 사용자만 댓글 작성 가능
        allow create: if isAuthenticated() && isValidCommentCreate(request.resource.data, request.auth.uid);
        // 댓글 작성자만 수정/삭제 가능
        allow update, delete: if isCommentOwner(reviewId, commentId);
      }
    }

    // Activities collection
    match /activities/{activityId} {
      // 모든 인증 사용자는 활동 피드 읽기 가능
      allow read: if isAuthenticated();
      // 활동 생성은 앱에서만 (보안 제약)
      allow create: if isAuthenticated() && isValidActivityCreate(request.resource.data, request.auth.uid);
      // 활동 소유자만 삭제 가능
      allow delete: if isOwner(request.resource.data.userId);
    }

    // Follows collection (선택사항 - 실제로는 users.followingIds, users.followerIds 사용)
    // 필요시 나중에 추가 가능

    // Validation functions
    function isValidUserCreate(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt']) &&
             data.email is string &&
             data.displayName is string &&
             data.uid is string &&
             data.createdAt is timestamp;
    }

    function isValidUserUpdate(data) {
      return (data.keys().size() > 0) &&
             (!('uid' in data.keys())) &&
             (!('email' in data.keys())) &&
             (!('createdAt' in data.keys())) &&
             (!'displayName' in data.keys() || data.displayName is string) &&
             (!'bio' in data.keys() || data.bio is string) &&
             (!'photoUrl' in data.keys() || data.photoUrl is string) &&
             (!'followerIds' in data.keys() || data.followerIds is list) &&
             (!'followingIds' in data.keys() || data.followingIds is list);
    }

    function isValidReviewCreate(data, userId) {
      return data.keys().hasAll(['cafeId', 'userId', 'rating', 'text', 'createdAt']) &&
             data.userId == userId &&
             data.rating is int &&
             data.rating >= 1 && data.rating <= 5 &&
             data.text is string &&
             data.text.size() > 0 &&
             data.text.size() <= 500 &&
             data.cafeId is string &&
             data.createdAt is timestamp;
    }

    function isValidCommentCreate(data, userId) {
      return data.keys().hasAll(['userId', 'text', 'createdAt']) &&
             data.userId == userId &&
             data.text is string &&
             data.text.size() > 0 &&
             data.text.size() <= 200 &&
             data.createdAt is timestamp;
    }

    function isValidActivityCreate(data, userId) {
      return data.keys().hasAll(['userId', 'type', 'createdAt']) &&
             data.userId == userId &&
             data.type is string &&
             data.type in ['follow', 'review_posted', 'review_liked', 'comment_added'] &&
             data.createdAt is timestamp;
    }

    // Catch-all: deny all other requests
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
